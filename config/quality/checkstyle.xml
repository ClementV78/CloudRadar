<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!-- CloudRadar shared Checkstyle configuration.
     Focuses on structural limits that catch god-class patterns early.
     Ref: https://github.com/ClementV78/CloudRadar/issues/557 -->
<module name="Checker">
  <property name="charset" value="UTF-8"/>
  <property name="severity" value="error"/>

  <!-- Known violations suppressed until refactoring -->
  <module name="SuppressionFilter">
    <property name="file" value="${config_loc}/checkstyle-suppressions.xml"/>
    <property name="optional" value="false"/>
  </module>

  <!-- File-level checks -->
  <module name="FileLength">
    <property name="max" value="400"/>
  </module>

  <module name="TreeWalker">
    <!-- Class-level method count -->
    <module name="MethodCount">
      <property name="maxTotal" value="15"/>
    </module>

    <!-- Coupling: how many other classes does this class depend on -->
    <module name="ClassDataAbstractionCoupling">
      <property name="max" value="12"/>
    </module>

    <!-- Fan-out: how many other classes does this class use -->
    <module name="ClassFanOutComplexity">
      <property name="max" value="25"/>
    </module>

    <!-- Per-method cyclomatic complexity -->
    <module name="CyclomaticComplexity">
      <property name="max" value="12"/>
    </module>

    <!-- Allow targeted suppression via @SuppressWarnings("checkstyle:...") -->
    <module name="SuppressWarningsHolder"/>
  </module>

  <!-- Enable @SuppressWarnings filter -->
  <module name="SuppressWarningsFilter"/>
</module>
